<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  xmlns:zeebe="http://camunda.org/schema/zeebe/1.0"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  targetNamespace="http://example.com/onboarding"
                  id="onboarding_defs">

  <!--
    Customer onboarding — the OUTER process. Runs on the Nano IDE gateway
    (models/ is auto-deployed on save). One service task 'verify_kyc' is
    served by the embedded KYC microservice under ../microservice/, which
    itself orchestrates the individual checks on its own in-process Bernd
    engine.

    Compliance owns kyc.bpmn (the inner flow); onboarding owns this file.
    Both are inspectable BPMN — audit trail = deploy both, log both instance
    keys.
  -->

  <bpmn:process id="onboarding" name="Customer Onboarding" isExecutable="true">
    <bpmn:startEvent id="start" name="New customer">
      <bpmn:outgoing>f_start</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:serviceTask id="verify_kyc" name="Verify KYC">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="verify_kyc" />
      </bpmn:extensionElements>
      <bpmn:incoming>f_start</bpmn:incoming>
      <bpmn:outgoing>f_to_gate</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:exclusiveGateway id="kyc_gate" name="KYC decision">
      <bpmn:incoming>f_to_gate</bpmn:incoming>
      <bpmn:outgoing>f_approved</bpmn:outgoing>
      <bpmn:outgoing>f_manual</bpmn:outgoing>
      <bpmn:outgoing>f_rejected</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:serviceTask id="activate_account" name="Activate account">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="activate_account" />
      </bpmn:extensionElements>
      <bpmn:incoming>f_approved</bpmn:incoming>
      <bpmn:outgoing>f_activated</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="queue_for_ops" name="Queue for manual review">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="queue_for_ops" />
      </bpmn:extensionElements>
      <bpmn:incoming>f_manual</bpmn:incoming>
      <bpmn:outgoing>f_queued</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="notify_rejection" name="Notify rejection">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="notify_rejection" />
      </bpmn:extensionElements>
      <bpmn:incoming>f_rejected</bpmn:incoming>
      <bpmn:outgoing>f_notified</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:endEvent id="end_approved" name="Onboarded">
      <bpmn:incoming>f_activated</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="end_manual" name="Manual review">
      <bpmn:incoming>f_queued</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="end_rejected" name="Rejected">
      <bpmn:incoming>f_notified</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="f_start" sourceRef="start" targetRef="verify_kyc" />
    <bpmn:sequenceFlow id="f_to_gate" sourceRef="verify_kyc" targetRef="kyc_gate" />
    <bpmn:sequenceFlow id="f_approved" name="approved" sourceRef="kyc_gate" targetRef="activate_account">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=decision = "approved"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="f_manual" name="manual review" sourceRef="kyc_gate" targetRef="queue_for_ops">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=decision = "manual_review"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="f_rejected" name="rejected" sourceRef="kyc_gate" targetRef="notify_rejection">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=decision = "rejected"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="f_activated" sourceRef="activate_account" targetRef="end_approved" />
    <bpmn:sequenceFlow id="f_queued" sourceRef="queue_for_ops" targetRef="end_manual" />
    <bpmn:sequenceFlow id="f_notified" sourceRef="notify_rejection" targetRef="end_rejected" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_onboarding">
    <bpmndi:BPMNPlane id="BPMNPlane_onboarding" bpmnElement="onboarding">
      <bpmndi:BPMNShape id="start_di" bpmnElement="start">
        <dc:Bounds x="180" y="182" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="168" y="225" width="61" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="verify_kyc_di" bpmnElement="verify_kyc">
        <dc:Bounds x="270" y="160" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="kyc_gate_di" bpmnElement="kyc_gate" isMarkerVisible="true">
        <dc:Bounds x="425" y="175" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="411" y="145" width="78" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="activate_account_di" bpmnElement="activate_account">
        <dc:Bounds x="530" y="60" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="queue_for_ops_di" bpmnElement="queue_for_ops">
        <dc:Bounds x="530" y="160" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="notify_rejection_di" bpmnElement="notify_rejection">
        <dc:Bounds x="530" y="280" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="end_approved_di" bpmnElement="end_approved">
        <dc:Bounds x="690" y="82" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="680" y="125" width="57" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="end_manual_di" bpmnElement="end_manual">
        <dc:Bounds x="690" y="182" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="676" y="225" width="66" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="end_rejected_di" bpmnElement="end_rejected">
        <dc:Bounds x="690" y="302" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="684" y="345" width="49" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="f_start_di" bpmnElement="f_start">
        <di:waypoint x="216" y="200" />
        <di:waypoint x="270" y="200" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f_to_gate_di" bpmnElement="f_to_gate">
        <di:waypoint x="370" y="200" />
        <di:waypoint x="425" y="200" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f_approved_di" bpmnElement="f_approved">
        <di:waypoint x="450" y="175" />
        <di:waypoint x="450" y="100" />
        <di:waypoint x="530" y="100" />
        <bpmndi:BPMNLabel><dc:Bounds x="459" y="135" width="52" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f_manual_di" bpmnElement="f_manual">
        <di:waypoint x="475" y="200" />
        <di:waypoint x="530" y="200" />
        <bpmndi:BPMNLabel><dc:Bounds x="472" y="182" width="80" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f_rejected_di" bpmnElement="f_rejected">
        <di:waypoint x="450" y="225" />
        <di:waypoint x="450" y="320" />
        <di:waypoint x="530" y="320" />
        <bpmndi:BPMNLabel><dc:Bounds x="459" y="290" width="47" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f_activated_di" bpmnElement="f_activated">
        <di:waypoint x="630" y="100" />
        <di:waypoint x="690" y="100" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f_queued_di" bpmnElement="f_queued">
        <di:waypoint x="630" y="200" />
        <di:waypoint x="690" y="200" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f_notified_di" bpmnElement="f_notified">
        <di:waypoint x="630" y="320" />
        <di:waypoint x="690" y="320" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
