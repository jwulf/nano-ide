{
  "id": "java-throughput",
  "kind": "example",
  "displayName": "Java throughput demo (C8 REST/gRPC ↔ Nano Falcon)",
  "requires": ["java"],
  "appDir": "app",
  "summary": "Java + Maven producer + JobWorker that maxes out create/complete throughput. Same code runs against Camunda 8 (REST or gRPC) or Nano (Falcon transport) — swap one Maven dependency.",
  "toolchain": {
    "detect": ["mvn", "--version"],
    "run": ["mvn", "-q", "-Pstock", "compile", "exec:java", "-Dexec.args=rest"],
    "compile": ["mvn", "-q", "-Pstock", "-DskipTests", "package"],
    "targets": [],
    "runConfigs": [
      {
        "id": "stock-rest",
        "label": "Camunda 8 · REST",
        "default": true,
        "run": ["mvn", "-q", "-Pstock", "compile", "exec:java", "-Dexec.args=rest"],
        "compile": ["mvn", "-q", "-Pstock", "-DskipTests", "package"]
      },
      {
        "id": "stock-grpc",
        "label": "Camunda 8 · gRPC",
        "run": ["mvn", "-q", "-Pstock", "compile", "exec:java", "-Dexec.args=grpc"],
        "compile": ["mvn", "-q", "-Pstock", "-DskipTests", "package"]
      },
      {
        "id": "falcon-nano",
        "label": "Nano · Falcon",
        "run": ["mvn", "-q", "-Pfalcon", "compile", "exec:java", "-Dexec.args=falcon"],
        "compile": ["mvn", "-q", "-Pfalcon", "-DskipTests", "package"]
      }
    ]
  }
}
