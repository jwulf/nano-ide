<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
  <modelVersion>4.0.0</modelVersion>

  <groupId>com.example</groupId>
  <artifactId>throughput-demo</artifactId>
  <version>0.1.0</version>
  <packaging>jar</packaging>

  <name>Throughput demo — same code, four transports</name>
  <description>
    Same BPMN, same source, one env var picks the server (C8 vs Nano),
    one Maven profile picks the SDK jar (REST/gRPC only vs Falcon-aware).
    Prints PIs/s + p50/p95/p99 completion latency.
  </description>

  <properties>
    <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
    <maven.compiler.source>17</maven.compiler.source>
    <maven.compiler.target>17</maven.compiler.target>

    <!-- Pin both versions here so the profiles below just pick the coordinate. -->
    <camunda.version>8.9.11</camunda.version>
    <camunda-falcon.version>1.1.0</camunda-falcon.version>
  </properties>

  <!--
    Two profiles, one dependency each. The Java source imports only from
    io.camunda.client.* — that package resolves against whichever jar is
    on the classpath:

      * default profile  : upstream io.camunda:camunda-client-java
                           - REST + gRPC only. Ideal against Camunda 8.
      * -Pfalcon         : io.github.jwulf:camunda-client-java-falcon
                           - drop-in fork of the upstream jar (same
                             io.camunda.client.* classes, three of them
                             patched to auto-detect Nano's Falcon protocol).
                             Against Camunda 8 it behaves identically to
                             upstream (REST/gRPC); against Nano it opens
                             one WebSocket per CamundaClient and pushes
                             jobs. Set CAMUNDA_FORCE_REST=1 to opt out.

    Because the API is identical the Java code doesn't need to know which
    is on the classpath. ThroughputDemo.clientCoordinate() prints the jar
    it actually loaded so results are self-documenting.
  -->
  <profiles>
    <profile>
      <id>upstream</id>
      <activation><activeByDefault>true</activeByDefault></activation>
      <dependencies>
        <dependency>
          <groupId>io.camunda</groupId>
          <artifactId>camunda-client-java</artifactId>
          <version>${camunda.version}</version>
        </dependency>
      </dependencies>
    </profile>
    <profile>
      <id>falcon</id>
      <dependencies>
        <dependency>
          <groupId>io.github.jwulf</groupId>
          <artifactId>camunda-client-java-falcon</artifactId>
          <version>${camunda-falcon.version}</version>
        </dependency>
      </dependencies>
    </profile>
  </profiles>

  <dependencies>
    <dependency>
      <groupId>org.hdrhistogram</groupId>
      <artifactId>HdrHistogram</artifactId>
      <version>2.2.2</version>
    </dependency>
    <dependency>
      <groupId>org.slf4j</groupId>
      <artifactId>slf4j-simple</artifactId>
      <version>2.0.13</version>
    </dependency>
    <dependency>
      <groupId>org.junit.jupiter</groupId>
      <artifactId>junit-jupiter</artifactId>
      <version>5.11.0</version>
      <scope>test</scope>
    </dependency>
  </dependencies>

  <build>
    <plugins>
      <plugin>
        <groupId>org.codehaus.mojo</groupId>
        <artifactId>exec-maven-plugin</artifactId>
        <version>3.4.1</version>
        <configuration>
          <mainClass>com.example.ThroughputDemo</mainClass>
        </configuration>
      </plugin>
      <plugin>
        <artifactId>maven-shade-plugin</artifactId>
        <version>3.6.0</version>
        <executions>
          <execution>
            <phase>package</phase>
            <goals><goal>shade</goal></goals>
            <configuration>
              <transformers>
                <transformer implementation="org.apache.maven.plugins.shade.resource.ManifestResourceTransformer">
                  <mainClass>com.example.ThroughputDemo</mainClass>
                </transformer>
                <transformer implementation="org.apache.maven.plugins.shade.resource.ServicesResourceTransformer"/>
              </transformers>
              <createDependencyReducedPom>false</createDependencyReducedPom>
            </configuration>
          </execution>
        </executions>
      </plugin>
    </plugins>
  </build>
</project>
