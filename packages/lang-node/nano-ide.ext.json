    "run": ["npm", "start"],
    "compile": ["npm", "run", "typecheck"],
    "installUrl": "https://nodejs.org/en/download",
    "installHint": "`node` (>= 22.6) was not found. Install Node.js from https://nodejs.org — the c8ctl npm launcher already ships a compatible one."
  }
