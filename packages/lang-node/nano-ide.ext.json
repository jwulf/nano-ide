  "icon": "<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24'><path d='M12 1.6 3 6.8v10.4l9 5.2 9-5.2V6.8z' fill='#339933'/><path d='M12 6.4c-2.9 0-4.7 1.4-4.7 3.4 0 2.2 1.7 2.8 4.4 3.4 2 .4 2.4.7 2.4 1.3 0 .6-.6 1.1-1.9 1.1-1.6 0-2.2-.7-2.3-1.5h-2c.1 1.9 1.5 3.3 4.3 3.3 2.9 0 4.6-1.3 4.6-3.4 0-2.2-1.9-2.9-4.5-3.4-2-.4-2.3-.7-2.3-1.3 0-.5.5-1 1.7-1 1.3 0 1.8.5 1.9 1.4h2c-.1-1.9-1.5-3.1-3.9-3.1z' fill='#fff'/></svg>",
  "fileTypes": [
    { "ext": ".ts", "monacoLang": "typescript" },
    { "ext": ".mts", "monacoLang": "typescript" },
    { "ext": ".js", "monacoLang": "javascript" },
    { "ext": ".mjs", "monacoLang": "javascript" }
