{
  "name": "nano-ide",
  "private": true,
  "version": "0.0.0",
  "description": "Monorepo for nano-ide extension packages: language + app packs for the Nano RAD console.",
  "license": "Apache-2.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/jwulf/nano-ide.git"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "validate": "node scripts/validate-manifests.mjs",
    "check:intellisense": "npm run check:intellisense --workspaces --if-present",
    "gen:intellisense": "npm run gen:intellisense --workspaces --if-present"
  },
  "devDependencies": {
    "typescript": "^5.6.0"
  }
}
